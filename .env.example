# 🦞 ClawWizard Environment Variables Example
# Copy this file to .env and fill in your values
# Note: These values will be used by the OpenClaw Gateway.

# ─── LLM PROVIDER API KEYS ───────────────────────────────────

# Mainstream Providers
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GEMINI_API_KEY=xxx
DEEPSEEK_API_KEY=sk-xxx
GROQ_API_KEY=gsk_xxx

# Aggregators & Gateways
OPENROUTER_API_KEY=sk-or-v1-xxx
KILO_API_KEY=xxx
TOGETHER_API_KEY=xxx
CLOUDFLARE_AI_GATEWAY_API_KEY=xxx
AI_GATEWAY_API_KEY=xxx

# Specialized & Regional Providers
MOONSHOT_API_KEY=xxx
MISTRAL_API_KEY=xxx
XAI_API_KEY=xxx
ZHIPU_API_KEY=xxx
QIANFAN_ACCESS_KEY=xxx
MINIMAX_API_KEY=xxx
XIAOMI_API_KEY=xxx

# Privacy & Local
VENICE_API_KEY=vapi_xxx
OLLAMA_API_KEY=ollama-local
SYNTHETIC_API_KEY=sk-xxx

# Miscellaneous
DEEPGRAM_API_KEY=xxx
CUSTOM_API_KEY=xxx

# ─── MESSAGING CHANNEL TOKENS ───────────────────────────────

# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefghIJKLmnop

# Discord
DISCORD_BOT_TOKEN=xxx
DISCORD_APPLICATION_ID=xxx

# Slack (Socket Mode Recommended)
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_APP_TOKEN=xapp-xxx

# Signal
SIGNAL_NUMBER=+15551234567

# LINE
LINE_CHANNEL_ACCESS_TOKEN=xxx
LINE_CHANNEL_SECRET=xxx

# Feishu / Lark
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_ENCRYPT_KEY=xxx
FEISHU_VERIFICATION_TOKEN=xxx

# Matrix
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@bot:matrix.org
MATRIX_ACCESS_TOKEN=syt_xxx

# Others
MATTERMOST_BOT_TOKEN=xxx
MSTEAMS_APP_ID=xxx
NOSTR_PRIVATE_KEY=xxx
TWITCH_OAUTH_TOKEN=xxx
ZALO_BOT_TOKEN=xxx

# ─── GATEWAY SETTINGS ───────────────────────────────────────
OPENCLAW_PORT=18789
OPENCLAW_BIND=0.0.0.0
# TAILSCALE_AUTH_KEY=tskey-auth-xxx
